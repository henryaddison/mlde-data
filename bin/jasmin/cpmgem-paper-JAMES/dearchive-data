#!/bin/bash
# Wrapper script around gathering datasets and models for the CPMGEM paper re-write to be run on LOTUS2

#SBATCH --job-name="PhD backup"
#SBATCH --account=furflex
#SBATCH --partition=standard
#SBATCH --qos=standard
#SBATCH --mem=8G
#SBATCH --time=23:00:00

set -euo pipefail

# Datasets

ds_src=/gws/nopw/j04/bris_climdyn/henrya/bp-backups/moose/nc-datasets/
ds_dest=/gws/nopw/j04/furflex/henrya/cpmgem-paper-JAMES/moose/nc-datasets/

# cCPM pSTV 12em
# GCM pSTV 12em
# cCPM @ 60km
# GCM @ 60km
# cCPM linpr
# GCM linpr
# cCPM pSTV 1em-1ts
# GCM pSTV 1em-1ts

set -x

for ds in bham64_ccpm-4x_12em_psl-sphum4th-temp4th-vort4th_pr bham64_gcm-4x_12em_psl-sphum4th-temp4th-vort4th_pr bham64_ccpm-4x_12em_linpr_pr bham64_gcm-4x_12em_linpr_pr bham64_ccpm-60km_12em_pr_pr bham64_gcm-60km_12em_rawpr_pr bham64_gcm-4x_1em_psl-sphum4th-temp4th-vort4th_pr-historic bham64_ccpm-4x_1em_psl-sphum4th-temp4th-vort4th_pr-historic; do rsync -acvh ${ds_src}/${ds}/ ${ds_dest}/${ds}/; done

set +x


# Models

# bilinear
# U-Net
# CPMGEM pSTV 12em
# CPMGEM pSTV 1em-1ts

wd_src=/gws/nopw/j04/bris_climdyn/henrya/bp-backups/moose/workdirs/
wd_dest=/gws/nopw/j04/furflex/henrya/cpmgem-paper-JAMES/moose/workdirs/

set -x

for wd in id-linpr score-sde/deterministic/ukcp_local_pr_12em_plain_unet/bham_pSTV-ema-gradcl-256-batch score-sde/subvpsde/subvpsde/ukcp_local_pr_12em_cncsnpp_continuous score-sde/subvpsde/ukcp_local_pr_1em_cncsnpp_continuous/bham-4x_1em_pSTV_lowdata; do mkdir -p ${wd}; rsync -acvh ${wd_src}/${wd}/ ${wd_dest}/${wd}/; done

set +x

echo "DONE"
