#!/bin/bash
# Script for verifying data in a folder that has been copied from bp-backups to phd-submission on JASMIN

set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

src_root="/gws/nopw/j04/bris_climdyn/henrya/bp-backups"
dst_root="/gws/nopw/j04/furflex/henrya/phd-submission"

folder=$1

set -x
cd ${dst_root}/${folder}
find . -type f \( -not -name "checksum.txt" \) -exec md5sum '{}' ';' > checksum.txt
cd ${src_root}/${folder}
md5sum --check --quiet ${dst_root}/${folder}/checksum.txt
set +x
