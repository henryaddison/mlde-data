#!/bin/bash
# Wrapper script around backing up phd submission files to be run on LOTUS2

#SBATCH --job-name="verify PhD backup archives"
#SBATCH --account=furflex
#SBATCH --partition=standard
#SBATCH --qos=standard
#SBATCH --mem=8G
#SBATCH --time=23:00:00

set -euo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

set -x

cd /gws/nopw/j04/bris_climdyn/henrya/phd-submission/

cd workdirs
tar --compare --file=workdirs.tar.gz $(find * -maxdepth 0 -type d)
echo "Done workdirs"

cd ../moose
tar --compare --file=moose.tar.gz $(find * -maxdepth 0 -type d)
echo "Done moose"

set +x

echo Done
